# Discord bot token from the Discord developer portal
DISCORD_BOT_TOKEN=your_discord_bot_token_here

# Discord server (guild) where the bot is installed
DISCORD_GUILD_ID=123456789012345678

# Only this channel can run publish/unpublish commands
DISCORD_ALLOWED_CHANNEL_ID=123456789012345679

# SQLite database path inside the container
SQLITE_PATH=/app/data/cloudcord.sqlite

# Allow Docker service/container hostnames like http://rails:3000
ALLOW_CONTAINER_HOSTNAMES=true

# Extra comma-separated hostnames allowed in addition to the built-in local targets
ALLOWED_HOSTS=host.docker.internal,internal.local

# Comma-separated allowed port ranges
ALLOWED_PORT_RANGES=1-65535

# Cloudflare API token with tunnel edit and DNS edit permissions
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Tunnel token copied from the Cloudflare named tunnel connector page
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# Cloudflare account ID that owns the named tunnel
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# Cloudflare zone ID where DNS records will be created
CLOUDFLARE_ZONE_ID=your_cloudflare_zone_id

# Existing named tunnel UUID
CLOUDFLARE_TUNNEL_ID=your_cloudflare_tunnel_id

# Base domain or subdomain used for generated public hostnames
CLOUDFLARE_BASE_DOMAIN=dev.example.com

# Log verbosity: debug, info, warn, or error
LOG_LEVEL=info
